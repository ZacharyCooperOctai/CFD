# Makefile generated by OpenModelica
# Platform: win64

# Simulations use -O3 by default
CC=clang
CXX=clang++
LINK=clang++ -shared -Xlinker --export-all-symbols
EXEEXT=.exe
DLLEXT=.dll
CFLAGS_BASED_ON_INIT_FILE=
# define OMC_CFLAGS_OPTIMIZATION env variable to your desired optimization level to override this
OMC_CFLAGS_OPTIMIZATION=-Os
DEBUG_FLAGS=$(OMC_CFLAGS_OPTIMIZATION)
CFLAGS=-municode $(CFLAGS_BASED_ON_INIT_FILE) $(DEBUG_FLAGS) -DOM_HAVE_PTHREADS -Wno-parentheses-equality -falign-functions -mstackrealign -msse2 -mfpmath=sse ${MODELICAUSERCFLAGS}   
CPPFLAGS="-IC:/Users/ZacharyCooper-Baldoc/AppData/Roaming/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/C-Sources" "-IC:/OMLibs/modelica-buildings/Buildings/Resources/C-Sources" -I"C:/OpenModelica/include/omc/c" -I"C:/OpenModelica/include/omc" -I. -DOPENMODELICA_XML_FROM_FILE_AT_RUNTIME -DOMC_MODEL_PREFIX=s000_baseline -DOMC_NUM_MIXED_SYSTEMS=0 -DOMC_NUM_LINEAR_SYSTEMS=3 -DOMC_NUM_NONLINEAR_SYSTEMS=15 -DOMC_NDELAY_EXPRESSIONS=0 -DOMC_NVAR_STRING=0
# define OMC_LDFLAGS_LINK_TYPE env variable to "static" to override this
OMC_LDFLAGS_LINK_TYPE=dynamic
RUNTIME_LIBS=-lSimulationRuntimeC -Wl,-Bdynamic -lomcgc -lryu -lopenblas -Wl,-B$(OMC_LDFLAGS_LINK_TYPE)  -lstdc++ -Wl,-Bdynamic 
LDFLAGS=-L"C:/OpenModelica/lib//omc" -L"C:/OpenModelica/lib" -Wl,--stack,16777216,-rpath,"C:/OpenModelica/lib//omc" -L"C:/OpenModelica/bin" -Wl,-rpath,"C:/OpenModelica/lib"  -fopenmp -Wl,-Bstatic -lregex -ltre -lintl -liconv -lexpat -lpthread -loleaut32 -limagehlp -lhdf5 -lz -lsz -Wl,-Bdynamic $(RUNTIME_LIBS) 
DIREXTRA=-L"C:/Users/ZacharyCooper-Baldoc/Desktop/Repositories/CFD/scenarios"
MAINFILE=s000_baseline.c
MAINOBJ=s000_baseline.o
CFILES=s000_baseline_functions.c s000_baseline_records.c \
s000_baseline_01exo.c s000_baseline_02nls.c s000_baseline_03lsy.c s000_baseline_04set.c s000_baseline_05evt.c s000_baseline_06inz.c s000_baseline_07dly.c \
s000_baseline_08bnd.c s000_baseline_09alg.c s000_baseline_10asr.c s000_baseline_11mix.c s000_baseline_12jac.c s000_baseline_13opt.c s000_baseline_14lnz.c \
s000_baseline_15syn.c s000_baseline_16dae.c s000_baseline_17inl.c s000_baseline_18spd.c \
   s000_baseline_08bnd_part0.c\
   s000_baseline_08bnd_part1.c\
   s000_baseline_08bnd_part2.c\
   s000_baseline_08bnd_part3.c\
   s000_baseline_06inz_part0.c\
   s000_baseline_06inz_part1.c

OFILES=$(CFILES:.c=.o)
GENERATEDFILES=$(MAINFILE) s000_baseline.makefile s000_baseline_literals.h s000_baseline_functions.h $(CFILES)

.PHONY: omc_main_target clean bundle

# This is to make sure that s000_baseline_*.c are always compiled.
.PHONY: $(CFILES)

omc_main_target: $(MAINOBJ) s000_baseline_functions.h s000_baseline_literals.h $(OFILES)
	$(CC) -I. -o s000_baseline$(EXEEXT) $(MAINOBJ) $(OFILES) $(DIREXTRA)  "-LC:/OpenModelica/bin/" "-LC:/OpenModelica/lib//omc" "-LC:/OpenModelica/lib/" "-LC:/Users/ZacharyCooper-Baldoc/AppData/Roaming/.openmodelica/binaries/Modelica" "-LC:/Users/ZacharyCooper-Baldoc/AppData/Roaming/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Library/mingw64" "-LC:/Users/ZacharyCooper-Baldoc/AppData/Roaming/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Library/ucrt64" "-LC:/Users/ZacharyCooper-Baldoc/AppData/Roaming/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Library/win64" "-LC:/Users/ZacharyCooper-Baldoc/AppData/Roaming/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Library" -lModelicaExternalC -lModelicaStandardTables -lModelicaIO -lModelicaMatIO -lzlib "-LC:/Users/ZacharyCooper-Baldoc/AppData/Roaming/.openmodelica/binaries/Buildings" "-LC:/OMLibs/modelica-buildings/Buildings/Resources/Library/mingw64" "-LC:/OMLibs/modelica-buildings/Buildings/Resources/Library/ucrt64" "-LC:/OMLibs/modelica-buildings/Buildings/Resources/Library/win64" "-LC:/OMLibs/modelica-buildings/Buildings/Resources/Library" -lffd $(CFLAGS) $(CPPFLAGS) $(LDFLAGS)

