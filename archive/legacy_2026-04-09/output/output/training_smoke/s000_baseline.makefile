	$(CC) -DOMC_DLL_MAIN_DEFINE -o $(MAINOBJ) -c $(MAINFILE) $(DIREXTRA)  "-LC:/OpenModelica/bin/" "-LC:/OpenModelica/lib//omc" "-LC:/OpenModelica/lib/" "-LC:/Users/ZacharyCooper-Baldoc/AppData/Roaming/.openmodelica/binaries/Modelica" "-LC:/Users/ZacharyCooper-Baldoc/AppData/Roaming/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Library/mingw64" "-LC:/Users/ZacharyCooper-Baldoc/AppData/Roaming/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Library/ucrt64" "-LC:/Users/ZacharyCooper-Baldoc/AppData/Roaming/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Library/win64" "-LC:/Users/ZacharyCooper-Baldoc/AppData/Roaming/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Library" -lModelicaExternalC -lModelicaStandardTables -lModelicaIO -lModelicaMatIO -lzlib "-LC:/Users/ZacharyCooper-Baldoc/AppData/Roaming/.openmodelica/binaries/Buildings" "-LC:/OMLibs/modelica-buildings/Buildings/Resources/Library/mingw64" "-LC:/OMLibs/modelica-buildings/Buildings/Resources/Library/ucrt64" "-LC:/OMLibs/modelica-buildings/Buildings/Resources/Library/win64" "-LC:/OMLibs/modelica-buildings/Buildings/Resources/Library" -lffd $(CFLAGS) $(CPPFLAGS) $(LDFLAGS)
	$(CC) -shared -I. -o s000_baseline$(DLLEXT) $(MAINOBJ) $(OFILES) $(DIREXTRA)  "-LC:/OpenModelica/bin/" "-LC:/OpenModelica/lib//omc" "-LC:/OpenModelica/lib/" "-LC:/Users/ZacharyCooper-Baldoc/AppData/Roaming/.openmodelica/binaries/Modelica" "-LC:/Users/ZacharyCooper-Baldoc/AppData/Roaming/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Library/mingw64" "-LC:/Users/ZacharyCooper-Baldoc/AppData/Roaming/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Library/ucrt64" "-LC:/Users/ZacharyCooper-Baldoc/AppData/Roaming/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Library/win64" "-LC:/Users/ZacharyCooper-Baldoc/AppData/Roaming/.openmodelica/libraries/Modelica 4.1.0+maint.om/Resources/Library" -lModelicaExternalC -lModelicaStandardTables -lModelicaIO -lModelicaMatIO -lzlib "-LC:/Users/ZacharyCooper-Baldoc/AppData/Roaming/.openmodelica/binaries/Buildings" "-LC:/OMLibs/modelica-buildings/Buildings/Resources/Library/mingw64" "-LC:/OMLibs/modelica-buildings/Buildings/Resources/Library/ucrt64" "-LC:/OMLibs/modelica-buildings/Buildings/Resources/Library/win64" "-LC:/OMLibs/modelica-buildings/Buildings/Resources/Library" -lffd $(CFLAGS) $(CPPFLAGS) $(LDFLAGS)

clean:
