  senTret[5].T = DataCentreFFD.senTret.Medium.temperature(DataCentreFFD.senTret.Medium.setState_phX(senTret[5].port.p, $OMC$inStreamDiv(($OMC$PositiveMax(-retSink[5].ports[1].m_flow, 1e-7) * retSink[5].ports[1].h_outflow + $OMC$PositiveMax(-roo.ports[11].m_flow, 1e-7) * roo.ports[11].h_outflow) / ($OMC$PositiveMax(-retSink[5].ports[1].m_flow, 1e-7) + $OMC$PositiveMax(-roo.ports[11].m_flow, 1e-7)), senTret[5].port.h_outflow), {$OMC$inStreamDiv(($OMC$PositiveMax(-retSink[5].ports[1].m_flow, 1e-7) * retSink[5].ports[1].Xi_outflow[1] + $OMC$PositiveMax(-roo.ports[11].m_flow, 1e-7) * roo.ports[11].Xi_outflow[1]) / ($OMC$PositiveMax(-retSink[5].ports[1].m_flow, 1e-7) + $OMC$PositiveMax(-roo.ports[11].m_flow, 1e-7)), senTret[5].port.Xi_outflow[1])}));
  senTret[5].port.m_flow = 0.0;
  senTret[5].port.h_outflow = 0.0;
  senTret[5].port.Xi_outflow[1] = 0.0;
  senTret[6].T = DataCentreFFD.senTret.Medium.temperature(DataCentreFFD.senTret.Medium.setState_phX(senTret[6].port.p, $OMC$inStreamDiv(($OMC$PositiveMax(-retSink[6].ports[1].m_flow, 1e-7) * retSink[6].ports[1].h_outflow + $OMC$PositiveMax(-roo.ports[12].m_flow, 1e-7) * roo.ports[12].h_outflow) / ($OMC$PositiveMax(-retSink[6].ports[1].m_flow, 1e-7) + $OMC$PositiveMax(-roo.ports[12].m_flow, 1e-7)), senTret[6].port.h_outflow), {$OMC$inStreamDiv(($OMC$PositiveMax(-retSink[6].ports[1].m_flow, 1e-7) * retSink[6].ports[1].Xi_outflow[1] + $OMC$PositiveMax(-roo.ports[12].m_flow, 1e-7) * roo.ports[12].Xi_outflow[1]) / ($OMC$PositiveMax(-retSink[6].ports[1].m_flow, 1e-7) + $OMC$PositiveMax(-roo.ports[12].m_flow, 1e-7)), senTret[6].port.Xi_outflow[1])}));
  senTret[6].port.m_flow = 0.0;
  senTret[6].port.h_outflow = 0.0;
  senTret[6].port.Xi_outflow[1] = 0.0;
  retSink[1].p_in_internal = retSink[1].p;
  retSink[1].ports[1].p = retSink[1].p_in_internal;
  retSink[1].T_in_internal = retSink[1].T;
  retSink[1].ports[1].h_outflow = retSink[1].h_internal;
  retSink[1].X_in_internal[1] = retSink[1].X[1];
  retSink[1].X_in_internal[2] = retSink[1].X[2];
  retSink[1].Xi_in_internal[1] = retSink[1].X[1];
  retSink[1].ports[1].Xi_outflow[1] = retSink[1].Xi_in_internal[1];
  retSink[2].p_in_internal = retSink[2].p;
  retSink[2].ports[1].p = retSink[2].p_in_internal;
  retSink[2].T_in_internal = retSink[2].T;
  retSink[2].ports[1].h_outflow = retSink[2].h_internal;
  retSink[2].X_in_internal[1] = retSink[2].X[1];
  retSink[2].X_in_internal[2] = retSink[2].X[2];
  retSink[2].Xi_in_internal[1] = retSink[2].X[1];
  retSink[2].ports[1].Xi_outflow[1] = retSink[2].Xi_in_internal[1];
  retSink[3].p_in_internal = retSink[3].p;
  retSink[3].ports[1].p = retSink[3].p_in_internal;
  retSink[3].T_in_internal = retSink[3].T;
  retSink[3].ports[1].h_outflow = retSink[3].h_internal;
  retSink[3].X_in_internal[1] = retSink[3].X[1];
  retSink[3].X_in_internal[2] = retSink[3].X[2];
  retSink[3].Xi_in_internal[1] = retSink[3].X[1];
  retSink[3].ports[1].Xi_outflow[1] = retSink[3].Xi_in_internal[1];
  retSink[4].p_in_internal = retSink[4].p;
  retSink[4].ports[1].p = retSink[4].p_in_internal;
  retSink[4].T_in_internal = retSink[4].T;
  retSink[4].ports[1].h_outflow = retSink[4].h_internal;
  retSink[4].X_in_internal[1] = retSink[4].X[1];
  retSink[4].X_in_internal[2] = retSink[4].X[2];
  retSink[4].Xi_in_internal[1] = retSink[4].X[1];
  retSink[4].ports[1].Xi_outflow[1] = retSink[4].Xi_in_internal[1];
  retSink[5].p_in_internal = retSink[5].p;
  retSink[5].ports[1].p = retSink[5].p_in_internal;
  retSink[5].T_in_internal = retSink[5].T;
  retSink[5].ports[1].h_outflow = retSink[5].h_internal;
  retSink[5].X_in_internal[1] = retSink[5].X[1];
  retSink[5].X_in_internal[2] = retSink[5].X[2];
  retSink[5].Xi_in_internal[1] = retSink[5].X[1];
  retSink[5].ports[1].Xi_outflow[1] = retSink[5].Xi_in_internal[1];
  retSink[6].p_in_internal = retSink[6].p;
  retSink[6].ports[1].p = retSink[6].p_in_internal;
  retSink[6].T_in_internal = retSink[6].T;
  retSink[6].ports[1].h_outflow = retSink[6].h_internal;
  retSink[6].X_in_internal[1] = retSink[6].X[1];
  retSink[6].X_in_internal[2] = retSink[6].X[2];
  retSink[6].Xi_in_internal[1] = retSink[6].X[1];
  retSink[6].ports[1].Xi_outflow[1] = retSink[6].Xi_in_internal[1];
  mFlowSet[1].y = mFlowSet[1].u1 * mFlowSet[1].u2;
  mFlowSet[2].y = mFlowSet[2].u1 * mFlowSet[2].u2;
  mFlowSet[3].y = mFlowSet[3].u1 * mFlowSet[3].u2;
  mFlowSet[4].y = mFlowSet[4].u1 * mFlowSet[4].u2;
  mFlowSet[5].y = mFlowSet[5].u1 * mFlowSet[5].u2;
  mFlowSet[6].y = mFlowSet[6].u1 * mFlowSet[6].u2;
  mFlowRated[1].y = mFlowRated[1].k;
  mFlowRated[2].y = mFlowRated[2].k;
  mFlowRated[3].y = mFlowRated[3].k;
  mFlowRated[4].y = mFlowRated[4].k;
  mFlowRated[5].y = mFlowRated[5].k;
  mFlowRated[6].y = mFlowRated[6].k;
  qSurBou[1].port.Q_flow = -qSurBou[1].Q_flow * (1.0 + qSurBou[1].alpha * (qSurBou[1].port.T - qSurBou[1].T_ref));
  qSurBou[2].port.Q_flow = -qSurBou[2].Q_flow * (1.0 + qSurBou[2].alpha * (qSurBou[2].port.T - qSurBou[2].T_ref));
  qSurBou[3].port.Q_flow = -qSurBou[3].Q_flow * (1.0 + qSurBou[3].alpha * (qSurBou[3].port.T - qSurBou[3].T_ref));
  qSurBou[4].port.Q_flow = -qSurBou[4].Q_flow * (1.0 + qSurBou[4].alpha * (qSurBou[4].port.T - qSurBou[4].T_ref));
  qSurBou[5].port.Q_flow = -qSurBou[5].Q_flow * (1.0 + qSurBou[5].alpha * (qSurBou[5].port.T - qSurBou[5].T_ref));
  qSurBou[6].port.Q_flow = -qSurBou[6].Q_flow * (1.0 + qSurBou[6].alpha * (qSurBou[6].port.T - qSurBou[6].T_ref));
algorithm
  when roo.air.cfd.sampleTrigger then
    (roo.air.cfd.modTimRea, roo.air.cfd.y, roo.air.cfd.retVal) := DataCentreFFD.roo.air.cfd.exchange(0, time, roo.air.cfd.samplePeriod, roo.air.cfd.uWri, 45, roo.air.cfd.yFixed, 32);
    assert(roo.air.cfd.retVal >= 0, "Obtained negative return value during data transfer with CFD.
       Aborting simulation. Check CFD log file.
       Received: retVal = " + String(roo.air.cfd.retVal, 0, true));
  end when;
end DataCentreFFD;
