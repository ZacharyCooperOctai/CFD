function Buildings.BoundaryConditions.WeatherData.BaseClasses.getAbsolutePath "Gets the absolute path of a URI"
  input String uri "A URI";
  output String path "The absolute path of the file pointed to by the URI";
algorithm
  path := OpenModelica_uriToFilename(uri);
end Buildings.BoundaryConditions.WeatherData.BaseClasses.getAbsolutePath;

impure function Buildings.ThermalZones.Detailed.BaseClasses.CFDThread.constructor "allocate memeory for cosimulation variables"
  output Buildings.ThermalZones.Detailed.BaseClasses.CFDThread FFDThre "the handler of FFD thread";

  external "C" FFDThre = cfdcosim();
end Buildings.ThermalZones.Detailed.BaseClasses.CFDThread.constructor;

impure function Buildings.ThermalZones.Detailed.BaseClasses.CFDThread.destructor "release ffd.dll or ffd.so"
  input Buildings.ThermalZones.Detailed.BaseClasses.CFDThread FFDThre "the handler of FFD thread";

  external "C" cfdSendStopCommand(FFDThre);
end Buildings.ThermalZones.Detailed.BaseClasses.CFDThread.destructor;

impure function Buildings.ThermalZones.Detailed.BaseClasses.cfdExchangeData "Exchange data between CFD and Modelica"
  input Integer flag "Communication flag to CFD";
  input Real t(quantity = "Time", unit = "s") "Current Modelica simulation time to CFD";
  input Real dt(quantity = "Time", unit = "s", min = 2.220446049250313e-14) "Requested synchronization time step size";
  input Real[nU] u "Input to CFD";
  input Integer nU "Number of inputs to CFD";
  input Integer nY "Number of outputs from CFD";
  output Real modTimRea(quantity = "Time", unit = "s") "Current model time from CFD";
  output Real[nY] y "Output computed by CFD";
  output Integer retVal "Return value for CFD simulation status";

  external "C" retVal = cfdExchangeData(t, dt, u, nU, nY, modTimRea, y);
end Buildings.ThermalZones.Detailed.BaseClasses.cfdExchangeData;

impure function Buildings.ThermalZones.Detailed.BaseClasses.cfdStartCosimulation "Start the coupled simulation with CFD"
  input String cfdFilNam "CFD input file name";
  input String[nSur] name "Surface names";
  input Real[nSur] A(quantity = fill("Area", nSur), unit = fill("m2", nSur)) "Surface areas";
  input Real[nSur] til(quantity = fill("Angle", nSur), unit = fill("rad", nSur), displayUnit = fill("deg", nSur)) "Surface tilt";
  input enumeration(Temperature, HeatFlowRate)[nSur] bouCon "Type of boundary condition";
  input Integer nPorts(min = 0) "Number of fluid ports for the HVAC inlet and outlets";
  input String[nPorts] portName "Names of fluid ports as declared in the CFD input file";
  input Boolean haveSensor "Flag, true if the model has at least one sensor";
  input String[nSen] sensorName "Names of sensors as declared in the CFD input file";
  input Boolean haveShade "Flag, true if the windows have a shade";
  input Integer nSur "Number of surfaces";
  input Integer nSen(min = 0) "Number of sensors that are connected to CFD output";
  input Integer nConExtWin(min = 0) "number of exterior construction with window";
  input Integer nXi(min = 0) "Number of independent species";
  input Integer nC(min = 0) "Number of trace substances";
  input Real rho_start(quantity = "Density", unit = "kg/m3", displayUnit = "g/cm3", min = 0.0) "Density at initial state";
  output Integer retVal "Return value of the function (0 indicates CFD successfully started.)";

  external "C" retVal = cfdStartCosimulation(cfdFilNam, name, A, til, bouCon, nPorts, portName, haveSensor, sensorName, haveShade, nSur, nSen, nConExtWin, nXi, nC, rho_start);
end Buildings.ThermalZones.Detailed.BaseClasses.cfdStartCosimulation;

function DataCentreFFD.retSink.Medium.ThermodynamicState "Automatically generated record constructor for DataCentreFFD.retSink.Medium.ThermodynamicState"
  input Real p;
  input Real T;
  input Real[2] X;
  output ThermodynamicState res;
end DataCentreFFD.retSink.Medium.ThermodynamicState;

function DataCentreFFD.retSink.Medium.setState_pTX "Return thermodynamic state as function of p, T and composition X or Xi"
  input Real p(quantity = "Pressure", unit = "Pa", displayUnit = "bar", min = 0.0, max = 1e8, start = 101325.0, nominal = 1e5) "Pressure";
  input Real T(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 1.0, max = 1e4, start = 293.15, nominal = 300.0) "Temperature";
  input Real[:] X(quantity = fill("MassFraction", size(X, 1)), unit = fill("kg/kg", size(X, 1)), min = fill(0.0, size(X, 1)), max = fill(1.0, size(X, 1)), nominal = fill(0.1, size(X, 1))) = {0.01, 0.99} "Mass fractions";
  output DataCentreFFD.retSink.Medium.ThermodynamicState state "Thermodynamic state record";
algorithm
  state := if size(X, 1) == 2 then DataCentreFFD.retSink.Medium.ThermodynamicState(p, T, X) else DataCentreFFD.retSink.Medium.ThermodynamicState(p, T, cat(1, X, {1.0 - sum(X)}));
end DataCentreFFD.retSink.Medium.setState_pTX;

function DataCentreFFD.retSink.Medium.specificEnthalpy "Compute specific enthalpy from pressure, temperature and mass fraction"
  input DataCentreFFD.retSink.Medium.ThermodynamicState state "Thermodynamic state record";
  output Real h(quantity = "SpecificEnergy", unit = "J/kg", min = -1e10, max = 1e10, nominal = 1e6) "Specific enthalpy";
algorithm
  h := (state.T - 273.15) * 1006.0 * (1.0 - state.X[1]) + ((state.T - 273.15) * 1860.0 + 2.5010145e6) * state.X[1];
end DataCentreFFD.retSink.Medium.specificEnthalpy;

function DataCentreFFD.roo.air.Medium.ThermodynamicState "Automatically generated record constructor for DataCentreFFD.roo.air.Medium.ThermodynamicState"
  input Real p;
  input Real T;
  input Real[2] X;
  output ThermodynamicState res;
end DataCentreFFD.roo.air.Medium.ThermodynamicState;

function DataCentreFFD.roo.air.Medium.density "Gas density"
  input DataCentreFFD.roo.air.Medium.ThermodynamicState state;
  output Real d(quantity = "Density", unit = "kg/m3", displayUnit = "g/cm3", min = 0.0, max = 1e5, start = 1.0, nominal = 1.0) "Density";
algorithm
  d := state.p * 1.2 / 101325.0;
end DataCentreFFD.roo.air.Medium.density;

function DataCentreFFD.roo.air.Medium.setState_pTX "Return thermodynamic state as function of p, T and composition X or Xi"
  input Real p(quantity = "Pressure", unit = "Pa", displayUnit = "bar", min = 0.0, max = 1e8, start = 101325.0, nominal = 1e5) "Pressure";
  input Real T(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 1.0, max = 1e4, start = 293.15, nominal = 300.0) "Temperature";
  input Real[:] X(quantity = fill("MassFraction", size(X, 1)), unit = fill("kg/kg", size(X, 1)), min = fill(0.0, size(X, 1)), max = fill(1.0, size(X, 1)), nominal = fill(0.1, size(X, 1))) = {0.01, 0.99} "Mass fractions";
  output DataCentreFFD.roo.air.Medium.ThermodynamicState state "Thermodynamic state record";
algorithm
  state := if size(X, 1) == 2 then DataCentreFFD.roo.air.Medium.ThermodynamicState(p, T, X) else DataCentreFFD.roo.air.Medium.ThermodynamicState(p, T, cat(1, X, {1.0 - sum(X)}));
end DataCentreFFD.roo.air.Medium.setState_pTX;

function DataCentreFFD.roo.air.cfd.assertStringsAreUnique
  input String descriptiveName "Descriptive name of what is tested, such as 'sensor' or 'ports'";
  input Integer n(min = 2) "Number of strings";
  input String[n] names "Names";
  protected Boolean[n - 1] ideNam "Flag that is set to true if the name is used more than once";
algorithm
  if n > 1 then
    for i in 1:n - 1 loop
      for j in i + 1:n loop
        ideNam[i] := Modelica.Utilities.Strings.isEqual(names[i], names[j], true);
        if ideNam[i] then
          break;
        end if;
      end for;
    end for;
    assert(not Modelica.Math.BooleanVectors.anyTrue(ideNam), "For the CFD interface, all " + descriptiveName + " must have a name that is unique within each room.
          The following " + descriptiveName + " names are used more than once in the room model:" + DataCentreFFD.roo.air.cfd.returnNonUniqueStrings(n, ideNam, names));
  else
    ideNam := fill(false, max(0, n - 1));
  end if;
end DataCentreFFD.roo.air.cfd.assertStringsAreUnique;

impure function DataCentreFFD.roo.air.cfd.exchange
  input Integer flag "Communication flag to write to CFD";
  input Real t(quantity = "Time", unit = "s") "Current simulation time in seconds to write";
  input Real dt(quantity = "Time", unit = "s", min = 2.220446049250313e-14) "Requested time step length";
  input Real[nU] u "Input for CFD";
  input Integer nU "Number of inputs for CFD";
  input Real[nY] yFixed "Fixed values (used for debugging only)";
  input Integer nY "Number of outputs from CFD";
  output Real modTimRea(quantity = "Time", unit = "s") "Current model time in seconds read from CFD";
  output Real[nY] y "Output computed by CFD";
  output Integer retVal "The exit value, which is negative if an error occurred";
algorithm
  (modTimRea, y, retVal) := Buildings.ThermalZones.Detailed.BaseClasses.cfdExchangeData(flag, t, dt, u, nU, nY);
end DataCentreFFD.roo.air.cfd.exchange;

function DataCentreFFD.roo.air.cfd.returnNonUniqueStrings
  input Integer n(min = 2) "Number entries";
  input Boolean[n - 1] ideNam "Flag that is set to true if the name is used more than once";
  input String[n] names "Names";
  output String s "String with non-unique names";
algorithm
  s := "";
  for i in 1:n - 1 loop
    if ideNam[i] then
      s := s + "
        '" + names[i] + "'";
    end if;
  end for;
end DataCentreFFD.roo.air.cfd.returnNonUniqueStrings;

impure function DataCentreFFD.roo.air.cfd.sendParameters
  input String cfdFilNam "CFD input file name";
  input String[nSur] name "Surface names";
  input Real[nSur] A(quantity = fill("Area", nSur), unit = fill("m2", nSur)) "Surface areas";
  input Real[nSur] til(quantity = fill("Angle", nSur), unit = fill("rad", nSur), displayUnit = fill("deg", nSur)) "Surface tilt";
  input enumeration(Temperature, HeatFlowRate)[nSur] bouCon "Type of boundary condition";
  input Integer nPorts(min = 0) "Number of fluid ports for the HVAC inlet and outlets";
  input String[nPorts] portName "Names of fluid ports as declared in the CFD input file";
  input Boolean haveSensor "Flag, true if the model has at least one sensor";
  input String[nSen] sensorName "Names of sensors as declared in the CFD input file";
  input Boolean haveShade "Flag, true if the windows have a shade";
  input Integer nSur(min = 2) "Number of surfaces";
  input Integer nSen(min = 0) "Number of sensors that are connected to CFD output";
  input Integer nConExtWin(min = 0) "number of exterior construction with window";
  input Integer nXi "Number of independent species concentration of the inflowing medium";
  input Integer nC "Number of trace substances of the inflowing medium";
  input Real rho_start(quantity = "Density", unit = "kg/m3", displayUnit = "g/cm3", min = 0.0) "Density at initial state";
  protected Integer coSimFlag = 0;
algorithm
  for i in 1:nSur loop
    assert(A[i] > 0.0, "Surface must be bigger than zero.");
  end for;
  coSimFlag := Buildings.ThermalZones.Detailed.BaseClasses.cfdStartCosimulation(cfdFilNam, name, A, til, bouCon, nPorts, portName, haveSensor, sensorName, haveShade, nSur, nSen, nConExtWin, nXi, nC, rho_start);
  assert(/*Real*/(coSimFlag) < 0.5, "Could not start the cosimulation.");
end DataCentreFFD.roo.air.cfd.sendParameters;

function DataCentreFFD.roo.air.fluInt.Medium.ThermodynamicState "Automatically generated record constructor for DataCentreFFD.roo.air.fluInt.Medium.ThermodynamicState"
  input Real p;
  input Real T;
  input Real[2] X;
  output ThermodynamicState res;
end DataCentreFFD.roo.air.fluInt.Medium.ThermodynamicState;

function DataCentreFFD.roo.air.fluInt.Medium.setState_pTX "Return thermodynamic state as function of p, T and composition X or Xi"
  input Real p(quantity = "Pressure", unit = "Pa", displayUnit = "bar", min = 0.0, max = 1e8, start = 101325.0, nominal = 1e5) "Pressure";
  input Real T(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 1.0, max = 1e4, start = 293.15, nominal = 300.0) "Temperature";
  input Real[:] X(quantity = fill("MassFraction", size(X, 1)), unit = fill("kg/kg", size(X, 1)), min = fill(0.0, size(X, 1)), max = fill(1.0, size(X, 1)), nominal = fill(0.1, size(X, 1))) = {0.01, 0.99} "Mass fractions";
  output DataCentreFFD.roo.air.fluInt.Medium.ThermodynamicState state "Thermodynamic state record";
algorithm
  state := if size(X, 1) == 2 then DataCentreFFD.roo.air.fluInt.Medium.ThermodynamicState(p, T, X) else DataCentreFFD.roo.air.fluInt.Medium.ThermodynamicState(p, T, cat(1, X, {1.0 - sum(X)}));
end DataCentreFFD.roo.air.fluInt.Medium.setState_pTX;

function DataCentreFFD.roo.air.fluInt.Medium.setState_phX "Return thermodynamic state as function of pressure p, specific enthalpy h and composition X"
  input Real p(quantity = "Pressure", unit = "Pa", displayUnit = "bar", min = 0.0, max = 1e8, start = 101325.0, nominal = 1e5) "Pressure";
  input Real h(quantity = "SpecificEnergy", unit = "J/kg", min = -1e10, max = 1e10, nominal = 1e6) "Specific enthalpy";
  input Real[:] X(quantity = fill("MassFraction", size(X, 1)), unit = fill("kg/kg", size(X, 1)), min = fill(0.0, size(X, 1)), max = fill(1.0, size(X, 1)), nominal = fill(0.1, size(X, 1))) = {0.01, 0.99} "Mass fractions";
  output DataCentreFFD.roo.air.fluInt.Medium.ThermodynamicState state "Thermodynamic state record";
algorithm
  state := if size(X, 1) == 2 then DataCentreFFD.roo.air.fluInt.Medium.ThermodynamicState(p, DataCentreFFD.roo.air.fluInt.Medium.temperature_phX(p, h, X), X) else DataCentreFFD.roo.air.fluInt.Medium.ThermodynamicState(p, DataCentreFFD.roo.air.fluInt.Medium.temperature_phX(p, h, X), cat(1, X, {1.0 - sum(X)}));
end DataCentreFFD.roo.air.fluInt.Medium.setState_phX;

function DataCentreFFD.roo.air.fluInt.Medium.specificEnthalpy "Compute specific enthalpy from pressure, temperature and mass fraction"
  input DataCentreFFD.roo.air.fluInt.Medium.ThermodynamicState state "Thermodynamic state record";
  output Real h(quantity = "SpecificEnergy", unit = "J/kg", min = -1e10, max = 1e10, nominal = 1e6) "Specific enthalpy";
algorithm
  h := (state.T - 273.15) * 1006.0 * (1.0 - state.X[1]) + ((state.T - 273.15) * 1860.0 + 2.5010145e6) * state.X[1];
end DataCentreFFD.roo.air.fluInt.Medium.specificEnthalpy;

function DataCentreFFD.roo.air.fluInt.Medium.specificEnthalpy_pTX "Specific enthalpy"
  input Real p(quantity = "Pressure", unit = "Pa", displayUnit = "bar") "Pressure";
  input Real T(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 0.0, start = 288.15, nominal = 300.0) "Temperature";
  input Real[:] X(quantity = fill("MassFraction", size(X, 1)), unit = fill("1", size(X, 1)), min = fill(0.0, size(X, 1)), max = fill(1.0, size(X, 1))) "Mass fractions of moist air";
  output Real h(quantity = "SpecificEnergy", unit = "J/kg") "Specific enthalpy at p, T, X";
algorithm
  h := DataCentreFFD.roo.air.fluInt.Medium.specificEnthalpy(DataCentreFFD.roo.air.fluInt.Medium.setState_pTX(p, T, X));
end DataCentreFFD.roo.air.fluInt.Medium.specificEnthalpy_pTX;

function DataCentreFFD.roo.air.fluInt.Medium.temperature "Return temperature of ideal gas as a function of the thermodynamic state record"
  input DataCentreFFD.roo.air.fluInt.Medium.ThermodynamicState state "Thermodynamic state record";
  output Real T(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 1.0, max = 1e4, start = 293.15, nominal = 300.0) "Temperature";
algorithm
  T := state.T;
end DataCentreFFD.roo.air.fluInt.Medium.temperature;

function DataCentreFFD.roo.air.fluInt.Medium.temperature_phX "Compute temperature from specific enthalpy and mass fraction"
  input Real p(quantity = "Pressure", unit = "Pa", displayUnit = "bar", min = 0.0, max = 1e8, start = 101325.0, nominal = 1e5) "Pressure";
  input Real h(quantity = "SpecificEnergy", unit = "J/kg", min = -1e10, max = 1e10, nominal = 1e6) "specific enthalpy";
  input Real[:] X(quantity = fill("MassFraction", size(X, 1)), unit = fill("kg/kg", size(X, 1)), min = fill(0.0, size(X, 1)), max = fill(1.0, size(X, 1)), nominal = fill(0.1, size(X, 1))) "mass fractions of composition";
  output Real T(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 1.0, max = 1e4, start = 293.15, nominal = 300.0) "temperature";
algorithm
  T := 273.15 + (h - 2.5010145e6 * X[1]) / ((1.0 - X[1]) * 1006.0 + X[1] * 1860.0);
end DataCentreFFD.roo.air.fluInt.Medium.temperature_phX;

function DataCentreFFD.roo.irRadExc.checkSurfaceAreas
  input Integer n "Number of surfaces";
  input Real[:] A(quantity = fill("Area", size(A, 1)), unit = fill("m2", size(A, 1))) "Surface areas";
  input String name "Name of the surface data record, used in error message";
algorithm
  if n == 0 then
    assert(Modelica.Math.Vectors.norm(A, 1.0) < 1e-10, "Error in declaration of room model: Construction record '" + name + "' has the following areas: " + Modelica.Math.Vectors.toString(A, "", 6) + "However, the room model is declared as having zero surfaces.
    Check the parameters of the room model.");
  else
    for i in 1:n loop
      assert(A[i] > 0.0, "Error in declaration of room model: Construction record '" + name + "' has the following areas: " + Modelica.Math.Vectors.toString(A, "", 6) + "However, the surface areas must be bigger than zero.
      Check the parameters of the room model.");
    end for;
  end if;
end DataCentreFFD.roo.irRadExc.checkSurfaceAreas;

