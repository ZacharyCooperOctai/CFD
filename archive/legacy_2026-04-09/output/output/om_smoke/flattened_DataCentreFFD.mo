  T := state.T;
end DataCentreFFD.senTret.Medium.temperature;

function DataCentreFFD.senTret.Medium.temperature_phX "Compute temperature from specific enthalpy and mass fraction"
  input Real p(quantity = "Pressure", unit = "Pa", displayUnit = "bar", min = 0.0, max = 1e8, start = 101325.0, nominal = 1e5) "Pressure";
  input Real h(quantity = "SpecificEnergy", unit = "J/kg", min = -1e10, max = 1e10, nominal = 1e6) "specific enthalpy";
  input Real[:] X(quantity = fill("MassFraction", size(X, 1)), unit = fill("kg/kg", size(X, 1)), min = fill(0.0, size(X, 1)), max = fill(1.0, size(X, 1)), nominal = fill(0.1, size(X, 1))) "mass fractions of composition";
  output Real T(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 1.0, max = 1e4, start = 293.15, nominal = 300.0) "temperature";
algorithm
  T := 273.15 + (h - 2.5010145e6 * X[1]) / ((1.0 - X[1]) * 1006.0 + X[1] * 1860.0);
end DataCentreFFD.senTret.Medium.temperature_phX;

function DataCentreFFD.senTsup.Medium.ThermodynamicState "Automatically generated record constructor for DataCentreFFD.senTsup.Medium.ThermodynamicState"
  input Real p;
  input Real T;
  input Real[2] X;
  output ThermodynamicState res;
end DataCentreFFD.senTsup.Medium.ThermodynamicState;

function DataCentreFFD.senTsup.Medium.setState_pTX "Return thermodynamic state as function of p, T and composition X or Xi"
  input Real p(quantity = "Pressure", unit = "Pa", displayUnit = "bar", min = 0.0, max = 1e8, start = 101325.0, nominal = 1e5) "Pressure";
  input Real T(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 1.0, max = 1e4, start = 293.15, nominal = 300.0) "Temperature";
  input Real[:] X(quantity = fill("MassFraction", size(X, 1)), unit = fill("kg/kg", size(X, 1)), min = fill(0.0, size(X, 1)), max = fill(1.0, size(X, 1)), nominal = fill(0.1, size(X, 1))) = {0.01, 0.99} "Mass fractions";
  output DataCentreFFD.senTsup.Medium.ThermodynamicState state "Thermodynamic state record";
algorithm
  state := if size(X, 1) == 2 then DataCentreFFD.senTsup.Medium.ThermodynamicState(p, T, X) else DataCentreFFD.senTsup.Medium.ThermodynamicState(p, T, cat(1, X, {1.0 - sum(X)}));
end DataCentreFFD.senTsup.Medium.setState_pTX;

function DataCentreFFD.senTsup.Medium.setState_phX "Return thermodynamic state as function of pressure p, specific enthalpy h and composition X"
  input Real p(quantity = "Pressure", unit = "Pa", displayUnit = "bar", min = 0.0, max = 1e8, start = 101325.0, nominal = 1e5) "Pressure";
  input Real h(quantity = "SpecificEnergy", unit = "J/kg", min = -1e10, max = 1e10, nominal = 1e6) "Specific enthalpy";
  input Real[:] X(quantity = fill("MassFraction", size(X, 1)), unit = fill("kg/kg", size(X, 1)), min = fill(0.0, size(X, 1)), max = fill(1.0, size(X, 1)), nominal = fill(0.1, size(X, 1))) = {0.01, 0.99} "Mass fractions";
  output DataCentreFFD.senTsup.Medium.ThermodynamicState state "Thermodynamic state record";
algorithm
  state := if size(X, 1) == 2 then DataCentreFFD.senTsup.Medium.ThermodynamicState(p, DataCentreFFD.senTsup.Medium.temperature_phX(p, h, X), X) else DataCentreFFD.senTsup.Medium.ThermodynamicState(p, DataCentreFFD.senTsup.Medium.temperature_phX(p, h, X), cat(1, X, {1.0 - sum(X)}));
end DataCentreFFD.senTsup.Medium.setState_phX;

function DataCentreFFD.senTsup.Medium.specificEnthalpy "Compute specific enthalpy from pressure, temperature and mass fraction"
  input DataCentreFFD.senTsup.Medium.ThermodynamicState state "Thermodynamic state record";
  output Real h(quantity = "SpecificEnergy", unit = "J/kg", min = -1e10, max = 1e10, nominal = 1e6) "Specific enthalpy";
algorithm
  h := (state.T - 273.15) * 1006.0 * (1.0 - state.X[1]) + ((state.T - 273.15) * 1860.0 + 2.5010145e6) * state.X[1];
end DataCentreFFD.senTsup.Medium.specificEnthalpy;

function DataCentreFFD.senTsup.Medium.specificEnthalpy_pTX "Specific enthalpy"
  input Real p(quantity = "Pressure", unit = "Pa", displayUnit = "bar") "Pressure";
  input Real T(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 0.0, start = 288.15, nominal = 300.0) "Temperature";
  input Real[:] X(quantity = fill("MassFraction", size(X, 1)), unit = fill("1", size(X, 1)), min = fill(0.0, size(X, 1)), max = fill(1.0, size(X, 1))) "Mass fractions of moist air";
  output Real h(quantity = "SpecificEnergy", unit = "J/kg") "Specific enthalpy at p, T, X";
algorithm
  h := DataCentreFFD.senTsup.Medium.specificEnthalpy(DataCentreFFD.senTsup.Medium.setState_pTX(p, T, X));
end DataCentreFFD.senTsup.Medium.specificEnthalpy_pTX;

function DataCentreFFD.senTsup.Medium.temperature "Return temperature of ideal gas as a function of the thermodynamic state record"
  input DataCentreFFD.senTsup.Medium.ThermodynamicState state "Thermodynamic state record";
  output Real T(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 1.0, max = 1e4, start = 293.15, nominal = 300.0) "Temperature";
algorithm
  T := state.T;
end DataCentreFFD.senTsup.Medium.temperature;

function DataCentreFFD.senTsup.Medium.temperature_phX "Compute temperature from specific enthalpy and mass fraction"
  input Real p(quantity = "Pressure", unit = "Pa", displayUnit = "bar", min = 0.0, max = 1e8, start = 101325.0, nominal = 1e5) "Pressure";
  input Real h(quantity = "SpecificEnergy", unit = "J/kg", min = -1e10, max = 1e10, nominal = 1e6) "specific enthalpy";
  input Real[:] X(quantity = fill("MassFraction", size(X, 1)), unit = fill("kg/kg", size(X, 1)), min = fill(0.0, size(X, 1)), max = fill(1.0, size(X, 1)), nominal = fill(0.1, size(X, 1))) "mass fractions of composition";
  output Real T(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 1.0, max = 1e4, start = 293.15, nominal = 300.0) "temperature";
algorithm
  T := 273.15 + (h - 2.5010145e6 * X[1]) / ((1.0 - X[1]) * 1006.0 + X[1] * 1860.0);
end DataCentreFFD.senTsup.Medium.temperature_phX;

function DataCentreFFD.sup.Medium.ThermodynamicState "Automatically generated record constructor for DataCentreFFD.sup.Medium.ThermodynamicState"
  input Real p;
  input Real T;
  input Real[2] X;
  output ThermodynamicState res;
end DataCentreFFD.sup.Medium.ThermodynamicState;

function DataCentreFFD.sup.Medium.setState_pTX "Return thermodynamic state as function of p, T and composition X or Xi"
  input Real p(quantity = "Pressure", unit = "Pa", displayUnit = "bar", min = 0.0, max = 1e8, start = 101325.0, nominal = 1e5) "Pressure";
  input Real T(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 1.0, max = 1e4, start = 293.15, nominal = 300.0) "Temperature";
  input Real[:] X(quantity = fill("MassFraction", size(X, 1)), unit = fill("kg/kg", size(X, 1)), min = fill(0.0, size(X, 1)), max = fill(1.0, size(X, 1)), nominal = fill(0.1, size(X, 1))) = {0.01, 0.99} "Mass fractions";
  output DataCentreFFD.sup.Medium.ThermodynamicState state "Thermodynamic state record";
algorithm
  state := if size(X, 1) == 2 then DataCentreFFD.sup.Medium.ThermodynamicState(p, T, X) else DataCentreFFD.sup.Medium.ThermodynamicState(p, T, cat(1, X, {1.0 - sum(X)}));
end DataCentreFFD.sup.Medium.setState_pTX;

function DataCentreFFD.sup.Medium.specificEnthalpy "Compute specific enthalpy from pressure, temperature and mass fraction"
  input DataCentreFFD.sup.Medium.ThermodynamicState state "Thermodynamic state record";
  output Real h(quantity = "SpecificEnergy", unit = "J/kg", min = -1e10, max = 1e10, nominal = 1e6) "Specific enthalpy";
algorithm
  h := (state.T - 273.15) * 1006.0 * (1.0 - state.X[1]) + ((state.T - 273.15) * 1860.0 + 2.5010145e6) * state.X[1];
end DataCentreFFD.sup.Medium.specificEnthalpy;

function Modelica.Fluid.Utilities.checkBoundary "Check whether boundary definition is correct"
  input String mediumName;
  input String[:] substanceNames "Names of substances";
  input Boolean singleState;
  input Boolean define_p;
  input Real[:] X_boundary;
  input String modelName = "??? boundary ???";
  protected Integer nX = size(X_boundary, 1);
  protected String X_str;
algorithm
  assert(not singleState or singleState and define_p, "
  Wrong value of parameter define_p (= false) in model "" + modelName + "":
  The selected medium "" + mediumName + "" has Medium.singleState=true.
  Therefore, an boundary density cannot be defined and
  define_p = true is required.
  ");
  for i in 1:nX loop
    assert(X_boundary[i] >= 0.0, "
    Wrong boundary mass fractions in medium "" + mediumName + "" in model "" + modelName + "":
    The boundary value X_boundary(" + String(i, 0, true) + ") = " + String(X_boundary[i], 6, 0, true) + "
    is negative. It must be positive.
    ");
  end for;
  if nX > 0 and abs(sum(X_boundary) - 1.0) > 1e-10 then
    X_str := "";
    for i in 1:nX loop
      X_str := X_str + "   X_boundary[" + String(i, 0, true) + "] = " + String(X_boundary[i], 6, 0, true) + " "" + substanceNames[i] + ""
      ";
    end for;
    Modelica.Utilities.Streams.error("The boundary mass fractions in medium "" + mediumName + "" in model "" + modelName + ""
    " + "do not sum up to 1. Instead, sum(X_boundary) = " + String(sum(X_boundary), 6, 0, true) + ":
    " + X_str);
  end if;
end Modelica.Fluid.Utilities.checkBoundary;

function Modelica.Math.BooleanVectors.anyTrue "Returns true, if at least one element of the Boolean input vector is true ('or')"
  input Boolean[:] b "Boolean vector";
  output Boolean result = size(b, 1) > 0 and max(b) "= true, if at least one element of b is true";
algorithm
end Modelica.Math.BooleanVectors.anyTrue;

function Modelica.Math.Vectors.norm "Return the p-norm of a vector"
  input Real[:] v "Real vector";
  input Real p(min = 1.0) = 2.0 "Type of p-norm (often used: 1, 2, or Modelica.Constants.inf)";
  output Real result = 0.0 "p-norm of vector v";
  protected Real eps = 2.220446049250313e-15;
algorithm
  if size(v, 1) > 0 then
    if p >= 2.0 - eps and p <= 2.0 + eps then
      result := sqrt(v * v);
    elseif p >= 1e60 then
      result := max(abs(v[$i0]) for $i0 in 1:size(v, 1));
    elseif p >= 1.0 - eps and p <= 1.0 + eps then
      result := sum(abs(v[$i1]) for $i1 in 1:size(v, 1));
    elseif p >= 1.0 then
      result := sum(abs(v[i]) ^ p for i in 1:size(v, 1)) ^ (1.0 / p);
    else
      assert(false, "Optional argument "p" (= " + String(p, 6, 0, true) + ") of function "norm" >= 1 required");
    end if;
  end if;
end Modelica.Math.Vectors.norm;

function Modelica.Math.Vectors.toString "Convert a real vector in to a string representation"
  input Real[:] v "Real vector";
  input String name = "" "Independent variable name used for printing";
  input Integer significantDigits = 6 "Number of significant digits that are shown";
  output String s = "";
  protected String blanks = Modelica.Utilities.Strings.repeat(significantDigits, " ");
  protected String space = "        ";
  protected Integer r = size(v, 1);
algorithm
  if r == 0 then
    s := if name == "" then "[]" else name + " = []";
  else
    s := if name == "" then "
    " else "
    " + name + " = 
    ";
    for i in 1:r loop
      s := s + space;
      if v[i] >= 0.0 then
        s := s + " ";
      end if;
      s := s + String(v[i], significantDigits, 0, true) + Modelica.Utilities.Strings.repeat(significantDigits + 8 - Modelica.Utilities.Strings.length(String(abs(v[i]), 6, 0, true)), " ");
      s := s + "
      ";
    end for;
  end if;
end Modelica.Math.Vectors.toString;

function Modelica.Utilities.Streams.error "Print error message and cancel all actions - in case of an unrecoverable error"
  input String string "String to be printed to error message window";
algorithm
  assert(false, string);
end Modelica.Utilities.Streams.error;

function Modelica.Utilities.Strings.compare "Compare two strings lexicographically"
  input String string1;
  input String string2;
  input Boolean caseSensitive = true "= false, if case of letters is ignored";
  output enumeration(Less, Equal, Greater) result "Result of comparison";

  external "C" result = ModelicaStrings_compare(string1, string2, caseSensitive);
end Modelica.Utilities.Strings.compare;

function Modelica.Utilities.Strings.isEqual "Determine whether two strings are identical"
  input String string1;
  input String string2;
  input Boolean caseSensitive = true "= false, if lower and upper case are ignored for the comparison";
  output Boolean identical "True, if string1 is identical to string2";
algorithm
  identical := Modelica.Utilities.Strings.compare(string1, string2, caseSensitive) == Modelica.Utilities.Types.Compare.Equal;
end Modelica.Utilities.Strings.isEqual;

function Modelica.Utilities.Strings.length "Return length of string"
  input String string;
  output Integer result "Number of characters of string";

  external "C" result = ModelicaStrings_length(string);
end Modelica.Utilities.Strings.length;

function Modelica.Utilities.Strings.repeat "Repeat a string n times"
  input Integer n(min = 0) = 1 "Number of occurrences";
  input String string = " " "String that is repeated";
  output String repeatedString "String containing n concatenated strings";
algorithm
  repeatedString := "";
  for i in 1:n loop
    repeatedString := repeatedString + string;
  end for;
end Modelica.Utilities.Strings.repeat;

class DataCentreFFD "FFD-coupled data-centre thermal model with 6 parametric CRAC units"
  final parameter Integer nCRAC = 6 "Number of CRAC units";
  parameter Real m_flow_rated(quantity = "MassFlowRate", unit = "kg/s") = 5.418 "Rated CRAC air mass flow rate (4.5 m³/s × 1.204 kg/m³)";
  parameter Real T_sup_rated(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 0.0, start = 288.15, nominal = 300.0) = 287.15 "Rated CRAC supply air temperature [K]";
  parameter Real T_init(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 0.0, start = 288.15, nominal = 300.0) = 295.15 "Initial domain temperature [K]";
  parameter Real samplePeriod(quantity = "Time", unit = "s") = 10.0 "FFD–Modelica data exchange interval [s]";
  final parameter Integer roo.nConExt(min = 0) = 0 "Number of exterior constructions";
  final parameter Integer roo.nConExtWin(min = 0) = 0 "Number of window constructions";
  final parameter Integer roo.nConPar(min = 0) = 0 "Number of partition constructions";
  final parameter Integer roo.nConBou(min = 0) = 6 "Number of constructions that have their outside surface exposed to the boundary of this room";
  final parameter Integer roo.nSurBou(min = 0) = 0 "Number of surface heat transfer models that connect to constructions that are modeled outside of this room";
  final parameter Integer roo.NConExt(min = 1) = 1 "Number of elements for exterior constructions";
  final parameter Integer roo.NConExtWin(min = 1) = 1 "Number of elements for exterior constructions with windows";
  final parameter Integer roo.NConPar(min = 1) = 1 "Number of elements for partition constructions";
  final parameter Integer roo.NConBou(min = 1) = 6 "Number of elements for constructions that have their outside surface exposed to the boundary of this room";
  final parameter Integer roo.NSurBou(min = 1) = 1 "Number of elements for surface heat transfer models that connect to constructions that are modeled outside of this room";
  final parameter Boolean roo.haveConExt = false "Flag to conditionally remove components";
  final parameter Boolean roo.haveConExtWin = false "Flag to conditionally remove components";
  final parameter Boolean roo.haveConPar = false "Flag to conditionally remove components";
  final parameter Boolean roo.haveConBou = true "Flag to conditionally remove components";
  final parameter Boolean roo.haveSurBou = false "Flag to conditionally remove components";
  parameter String roo.datConExt[1].name = "" "Surface name. Optional for MixedAir, required for FFD.";
  final parameter Integer roo.datConExt[1].layers.nLay(min = 1) = 1 "Number of layers";
  parameter Real roo.datConExt[1].layers.material[1].x(quantity = "Length", unit = "m") = 0.12 "Material thickness";
  parameter Real roo.datConExt[1].layers.material[1].k(quantity = "ThermalConductivity", unit = "W/(m.K)") = 0.89 "Thermal conductivity";
  parameter Real roo.datConExt[1].layers.material[1].c(quantity = "SpecificHeatCapacity", unit = "J/(kg.K)") = 790.0 "Specific heat capacity";
  parameter Real roo.datConExt[1].layers.material[1].d(quantity = "Density", unit = "kg/m3", displayUnit = "g/cm3", min = 0.0) = 1920.0 "Mass density";
  parameter Real roo.datConExt[1].layers.material[1].R(unit = "m2.K/W") = 0.1348314606741573 "Thermal resistance of a unit area of material";
  parameter Integer roo.datConExt[1].layers.material[1].nStaRef(min = 0) = 3 "Number of state variables in a reference material of 0.2 m concrete";
  parameter Integer roo.datConExt[1].layers.material[1].nSta(min = 1) = 2 "Actual number of state variables in material";
  parameter Boolean roo.datConExt[1].layers.material[1].steadyState = false "Flag, if true, then material is computed using steady-state heat conduction";
  parameter Real roo.datConExt[1].layers.material[1].piRef = 331.4 "Ratio x/sqrt(alpha) for reference material of 0.2 m concrete";
  parameter Real roo.datConExt[1].layers.material[1].piMat = 156.65721542931692 "Ratio x/sqrt(alpha)";
  parameter Real roo.datConExt[1].layers.material[1].nStaReal(min = 0.0) = 1.4181401517439673 "Number of states as a real number";
  final parameter Real roo.datConExt[1].layers.material[1].TSol(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 0.0, start = 288.15, nominal = 300.0) = 293.15 "Solidus temperature, used only for PCM.";
  final parameter Real roo.datConExt[1].layers.material[1].TLiq(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 0.0, start = 288.15, nominal = 300.0) = 293.15 "Liquidus temperature, used only for PCM";
  parameter Real roo.datConExt[1].layers.material[1].LHea(quantity = "SpecificEnergy", unit = "J/kg") = 0.0 "Latent heat of phase change";
  constant Boolean roo.datConExt[1].layers.material[1].ensureMonotonicity = false "Set to true to force derivatives dT/du to be monotone";
  constant Boolean roo.datConExt[1].layers.material[1].phasechange = false "Flag, true if the material is a phase change material";
  final parameter Real roo.datConExt[1].layers.R(unit = "m2.K/W") = 0.1348314606741573 "Thermal resistance per unit area";
  final parameter Integer roo.datConExt[1].layers.nSta[1](min = 1) = 2 "Number of states in each layer";
  parameter Real roo.datConExt[1].layers.absIR_a(quantity = "Emissivity", unit = "1") = 0.9 "Infrared absorptivity of surface a (usually outside-facing surface)";
  parameter Real roo.datConExt[1].layers.absIR_b(quantity = "Emissivity", unit = "1") = 0.9 "Infrared absorptivity of surface b (usually room-facing surface)";
  parameter Real roo.datConExt[1].layers.absSol_a(quantity = "Emissivity", unit = "1") = 0.5 "Solar absorptivity of surface a (usually outside-facing surface)";
  parameter Real roo.datConExt[1].layers.absSol_b(quantity = "Emissivity", unit = "1") = 0.5 "Solar absorptivity of surface b (usually room-facing surface)";
  parameter enumeration(VeryRough, Rough, Medium, MediumSmooth, Smooth, VerySmooth) roo.datConExt[1].layers.roughness_a = Buildings.HeatTransfer.Types.SurfaceRoughness.Medium "Exterior surface roughness";
  final parameter Real roo.datConExt[1].til(quantity = "Angle", unit = "rad", displayUnit = "deg") = 0.0 "Surface tilt";
  parameter Real roo.datConExt[1].azi(quantity = "Angle", unit = "rad", displayUnit = "deg") = 0.0 "Surface azimuth";
  final parameter Boolean roo.datConExt[1].is_floor = false "Flag, true if construction is a floor";
  final parameter Boolean roo.datConExt[1].is_ceiling = true "Flag, true if construction is a floor";
  final parameter Boolean roo.datConExt[1].steadyStateInitial = false "=true initializes dT(0)/dt=0, false initializes T(0) at fixed temperature using T_a_start and T_b_start";
  parameter Real roo.datConExt[1].T_a_start(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 0.0, start = 288.15, nominal = 300.0) = 293.15 "Initial temperature at port_a, used if steadyStateInitial = false";
  parameter Real roo.datConExt[1].T_b_start(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 0.0, start = 288.15, nominal = 300.0) = 293.15 "Initial temperature at port_b, used if steadyStateInitial = false";
  final parameter Boolean roo.datConExt[1].stateAtSurface_a = true "=true, a state will be at the surface a";
  final parameter Boolean roo.datConExt[1].stateAtSurface_b = true "=true, a state will be at the surface b";
  parameter enumeration(Temperature, HeatFlowRate) roo.datConExt[1].boundaryCondition = Buildings.ThermalZones.Detailed.Types.CFDBoundaryConditions.Temperature "Boundary condition used in the CFD simulation";
  parameter Real roo.datConExt[1].A(quantity = "Area", unit = "m2") = 0.0 "Heat transfer area";
  parameter String roo.datConExtWin[1].name = "" "Surface name. Optional for MixedAir, required for FFD.";
  final parameter Integer roo.datConExtWin[1].layers.nLay(min = 1) = 1 "Number of layers";
  parameter Real roo.datConExtWin[1].layers.material[1].x(quantity = "Length", unit = "m") = 0.12 "Material thickness";
  parameter Real roo.datConExtWin[1].layers.material[1].k(quantity = "ThermalConductivity", unit = "W/(m.K)") = 0.89 "Thermal conductivity";
  parameter Real roo.datConExtWin[1].layers.material[1].c(quantity = "SpecificHeatCapacity", unit = "J/(kg.K)") = 790.0 "Specific heat capacity";
  parameter Real roo.datConExtWin[1].layers.material[1].d(quantity = "Density", unit = "kg/m3", displayUnit = "g/cm3", min = 0.0) = 1920.0 "Mass density";
  parameter Real roo.datConExtWin[1].layers.material[1].R(unit = "m2.K/W") = 0.1348314606741573 "Thermal resistance of a unit area of material";
  parameter Integer roo.datConExtWin[1].layers.material[1].nStaRef(min = 0) = 3 "Number of state variables in a reference material of 0.2 m concrete";
  parameter Integer roo.datConExtWin[1].layers.material[1].nSta(min = 1) = 2 "Actual number of state variables in material";
  parameter Boolean roo.datConExtWin[1].layers.material[1].steadyState = false "Flag, if true, then material is computed using steady-state heat conduction";
  parameter Real roo.datConExtWin[1].layers.material[1].piRef = 331.4 "Ratio x/sqrt(alpha) for reference material of 0.2 m concrete";
  parameter Real roo.datConExtWin[1].layers.material[1].piMat = 156.65721542931692 "Ratio x/sqrt(alpha)";
  parameter Real roo.datConExtWin[1].layers.material[1].nStaReal(min = 0.0) = 1.4181401517439673 "Number of states as a real number";
  final parameter Real roo.datConExtWin[1].layers.material[1].TSol(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 0.0, start = 288.15, nominal = 300.0) = 293.15 "Solidus temperature, used only for PCM.";
  final parameter Real roo.datConExtWin[1].layers.material[1].TLiq(quantity = "ThermodynamicTemperature", unit = "K", displayUnit = "degC", min = 0.0, start = 288.15, nominal = 300.0) = 293.15 "Liquidus temperature, used only for PCM";
  parameter Real roo.datConExtWin[1].layers.material[1].LHea(quantity = "SpecificEnergy", unit = "J/kg") = 0.0 "Latent heat of phase change";
  constant Boolean roo.datConExtWin[1].layers.material[1].ensureMonotonicity = false "Set to true to force derivatives dT/du to be monotone";
  constant Boolean roo.datConExtWin[1].layers.material[1].phasechange = false "Flag, true if the material is a phase change material";
  final parameter Real roo.datConExtWin[1].layers.R(unit = "m2.K/W") = 0.1348314606741573 "Thermal resistance per unit area";
  final parameter Integer roo.datConExtWin[1].layers.nSta[1](min = 1) = 2 "Number of states in each layer";
  parameter Real roo.datConExtWin[1].layers.absIR_a(quantity = "Emissivity", unit = "1") = 0.9 "Infrared absorptivity of surface a (usually outside-facing surface)";
  parameter Real roo.datConExtWin[1].layers.absIR_b(quantity = "Emissivity", unit = "1") = 0.9 "Infrared absorptivity of surface b (usually room-facing surface)";
